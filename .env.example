# Copy this file to .env and fill in local values.
# .env and .env.* are ignored by git; .env.example is intentionally tracked.

# Required for `starsync sync` and `starsync enrich readme`.
# Recommended token permission for v1: fine-grained PAT with Starring: read.
STARSYNC_GITHUB_TOKEN=github_pat_replace_me

# Optional local paths.
# STARSYNC_DATA_DIR=~/.starsync/data
# STARSYNC_STATE_DIR=~/.starsync/state
# STARSYNC_SEARCH_INDEX_DIR=~/.starsync/state/search
# STARSYNC_UI_DIR=~/.starsync/ui

# Optional REST/Web UI bind address.
# STARSYNC_BIND=127.0.0.1:8989

# Optional embedded Web UI controls.
# STARSYNC_UI_ENABLED=true
# STARSYNC_UI_AUTO_EXTRACT=true

# Optional metadata storage backend.
# STARSYNC_STORAGE_BACKEND=local
# STARSYNC_STORAGE_BACKEND=git
# STARSYNC_GIT_REMOTE=git@github.com:you/starsync-meta.git
